# task-init config — generated by the skill on first run, editable by hand.
#
# Backend: local stores this file at .atl/task-init/config.yaml
#          engram stores it as observation `task-init/{project}/config`

version: 1
backend: __BACKEND__              # local | engram

airtable:
  # IDs of the Airtable base and table that hold the tasks
  base_id: __BASE_ID__
  table_id: __TABLE_ID__
  # filterByFormula used when /task-init runs in interactive mode (no ID arg).
  # Example: AND({Status} = "To Do", {Assignee} = "you@example.com")
  default_filter: |
    __DEFAULT_FILTER__
  # Logical field name -> real Airtable field name. Adjust to match your table.
  fields:
    id: "ID"
    title: "Title"
    description: "Description"
    type: "Type"
    status: "Status"
    assignee: "Assignee"

branch:
  # Placeholders: {type}, {id}, {slug}
  template: "{type}/{id}-{slug}"
  # Maps the Airtable `type` value to the branch prefix.
  # The 11 prefixes allowed by branch-pr regex:
  # feat, fix, chore, docs, style, refactor, perf, test, build, ci, revert
  type_map:
    feature: feat
    bug: fix
    test: test
    chore: chore
    docs: docs
    refactor: refactor
  # Suggested prefix when the task type cannot be resolved automatically.
  fallback_suggestion: chore
  # Branch the new branch is cut from.
  base: main

pr:
  draft: true
  # Conventional commits format. {id} is replaced with the task ID.
  empty_commit_message: "chore: init task ({id})"
  # Path (local backend) or topic key suffix (engram backend) of the PR template.
  template: templates/pr.tmpl
  # GitHub username added as PR assignee.
  assignee: __GH_USERNAME__
  # Labels added to the PR right after creation.
  labels:
    - "__IN_PROGRESS_LABEL__"
  auto_push: true

# Patch the Airtable record after the PR is created.
airtable_update:
  enabled: true
  status_field: "Status"
  in_progress_value: "In Progress"
  ask_confirmation: true
